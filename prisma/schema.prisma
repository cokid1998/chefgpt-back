generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

enum Food_Location {
  COLD
  FROZEN
  ROOM_TEMP
}

enum Option_Name {
  A
  B
}

enum AuthProvider {
  LOCAL
  KAKAO
}

enum Recipe_Source {
  YOUTUBE
  MANUAL
  CHATBOT
}

model User {
  id           Int      @id @default(autoincrement())
  createdAt    DateTime @default(now())
  email        String   @unique
  password     String?
  nickname     String?
  thumbnail    String?
  refreshToken String?

  authProvider AuthProvider

  // UserмЩА FoodмЭШ кіАк≥Д
  foods Food[]

  // UserмЩА VoteмЭШ кіАк≥Д
  voteUsers Vote_User[]

  // UserмЩА RecipeмЭШ кіАк≥Д
  recipes      Recipe[]
  recipeLikes  Recipe_Like[]
  articleLikes Article_Like[]
  votes        Vote[]
  articles     Article[]
}

model Food_Category {
  id   Int    @id @default(autoincrement())
  name String @unique

  // Food_CategoryмЩА FoodмЭШ кіАк≥Д
  foods Food[]
}

model Food {
  id              Int            @id @default(autoincrement())
  name            String
  location        Food_Location?
  quantity        Int?
  unit            String?
  expiration_date DateTime?      @db.Timestamptz()
  memo            String?

  // мЩЄлґАнВ§
  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  category   Food_Category @relation(fields: [categoryId], references: [id])
  categoryId Int

  @@index([userId])
  @@index([categoryId])
}

model Vote {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  optionA     String
  optionB     String
  startDate   DateTime
  endDate     DateTime

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // VoteмЩА UserмЭШ кіАк≥Д
  voteUsers Vote_User[]
}

model Vote_User {
  id           Int         @id @default(autoincrement())
  voteId       Int
  userId       Int
  selectOption Option_Name

  vote Vote @relation(fields: [voteId], references: [id])
  user User @relation(fields: [userId], references: [id])

  // лПЩмЭЉнХЬ userIdлКФ лПЩмЭЉнХЬ VoteIdл•Љ мЧђлЯђк∞Ь к∞АмІИ мИШ мЧЖмЭМ
  @@unique([voteId, userId])
}

model Article {
  id          Int            @id @default(autoincrement())
  createdAt   DateTime       @default(now())
  title       String
  summary     String?
  contentJSON String
  readingTime Int
  viewCount   Int            @default(0)
  like        Article_Like[]
  likeCount   Int            @default(0)

  // мЩЄлґАнВ§
  categoryId Int
  category   Article_Category @relation(fields: [categoryId], references: [id])

  articleTagRelations Article_Tag_Relation[]

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([categoryId])
  @@index([userId])
}

model Article_Like {
  id        Int @id @default(autoincrement())
  articleId Int
  userId    Int

  user    User    @relation(fields: [userId], references: [id])
  article Article @relation(fields: [articleId], references: [id])

  @@unique([articleId, userId])
}

model Article_Category {
  id   Int    @id @default(autoincrement())
  name String

  // ArticleкіАмЭШ кіАк≥Д
  articles Article[]
}

model Article_Tag {
  id   Int    @id @default(autoincrement())
  name String @unique

  articleTagRelations Article_Tag_Relation[]
}

model Article_Tag_Relation {
  articleId Int
  tagId     Int

  article Article     @relation(fields: [articleId], references: [id])
  tag     Article_Tag @relation(fields: [tagId], references: [id])

  @@id([articleId, tagId])
}

model Recipe {
  id                Int                 @id @default(autoincrement())
  title             String
  description       String
  cookingTime       String?
  recipeIngredients Recipe_Ingredient[]
  recipeSteps       Recipe_Step[]
  viewCount         Int                 @default(0)
  thumbnailUrl      String
  recipeSource      Recipe_Source
  youtubeVideoId    String? // recipeSourceк∞А "YOUTUBE"мЭЉ лХМ мЬ†нКЬлЄМId, "MANUAL"мЭЉ лХМ null
  like              Recipe_Like[]
  likeCount         Int                 @default(0)

  user   User @relation(fields: [userId], references: [id])
  userId Int

  categoryId Int
  category   Recipe_Category @relation(fields: [categoryId], references: [id])
}

model Recipe_Ingredient {
  id     Int    @id @default(autoincrement())
  name   String
  amount String

  recipeId Int
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
}

model Recipe_Step {
  id          Int     @id @default(autoincrement())
  stepNumber  Int
  stepTitle   String
  description String
  tip         String?

  recipeId Int
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
}

model Recipe_Category {
  id      Int      @id @default(autoincrement())
  name    String
  recipes Recipe[]
}

model Recipe_Like {
  id       Int @id @default(autoincrement())
  recipeId Int
  userId   Int

  user   User   @relation(fields: [userId], references: [id])
  recipe Recipe @relation(fields: [recipeId], references: [id])

  // лПЩмЭЉнХЬ userIdлКФ лПЩмЭЉнХЬ recipeIdл•Љ мЧђлЯђк∞Ь к∞АмІИ мИШ мЧЖмЭМ
  @@unique([recipeId, userId])
}
